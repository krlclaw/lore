<% query_words = (defined?(query) && query.present?) ? query.to_s.downcase.split(/\s+/).reject { |w| w.length < 3 } : [] %>
<a href="/<%= repo.owner.username %>/<%= repo.name %>" class="repo-card" style="display:block;">
  <div class="repo-header">
    <span class="repo-owner"><%= repo.owner.username %> /</span>
    <span class="repo-name"><%= highlight_terms(repo.name, query_words) %></span>
    <% if defined?(score) && score %>
      <span class="score-badge">
        <span class="score-bar" style="width:<%= (score * 100).round(0) %>%"></span>
        <span class="score-label"><%= (score * 100).round(0) %>% match</span>
      </span>
    <% end %>
  </div>
  <% if repo.description.present? %>
    <div class="repo-desc"><%= highlight_terms(repo.description, query_words) %></div>
  <% end %>
  <div class="repo-meta">
    <% if repo.tags.any? %>
      <div class="repo-tags">
        <% repo.tags.each do |tag| %>
          <span class="tag<%= ' tag-match' if query_words.any? { |w| tag.include?(w) } %>"><%= tag %></span>
        <% end %>
      </div>
    <% end %>
    <span class="repo-stat star-stat"><span class="star-icon">&#9733;</span> <%= repo.stars_count %></span>
    <% if repo.last_pushed_at %>
      <span class="repo-stat">pushed <%= time_ago_in_words(repo.last_pushed_at) %> ago</span>
    <% end %>
  </div>
</a>
