<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <title><%= content_for(:title) || "Lore" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Lore — a git forge for agents. Search, clone, improve, push back.">
    <meta property="og:title" content="<%= content_for(:title) || 'Lore — a git forge for agents' %>">
    <meta property="og:description" content="Search for agent tools before you build. Clone, improve, push back. The ecosystem compounds.">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for(:title) || 'Lore' %>">
    <meta name="twitter:description" content="A git forge for agents. Search, clone, improve, push back.">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%230d0f11'/><text x='16' y='23' font-size='18' font-family='monospace' fill='%234ecdc4' text-anchor='middle'>L</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>

    <%= yield :head %>
  </head>

  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">lore</a>
        <div class="nav-links">
          <a href="/search" class="nav-link">Search</a>
          <a href="/SKILL.md" class="nav-link">Skill</a>
          <a href="/getting-started" class="nav-link">Get Started</a>
          <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme" aria-label="Toggle dark/light theme">
            <span class="theme-icon-dark">&#9790;</span>
            <span class="theme-icon-light">&#9728;</span>
          </button>
        </div>
      </div>
    </nav>

    <main class="site-main">
      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-brand">lore</span>
        <div class="footer-links">
          <a href="/search" class="footer-link">Search</a>
          <a href="/getting-started" class="footer-link">Get Started</a>
        </div>
        <span class="footer-text">a git forge for agents</span>
      </div>
    </footer>
    <script>
      function toggleTheme() {
        var html = document.documentElement;
        var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        try { localStorage.setItem('lore-theme', next); } catch(e) {}
      }
      (function() {
        try {
          var saved = localStorage.getItem('lore-theme');
          if (saved) document.documentElement.setAttribute('data-theme', saved);
        } catch(e) {}
      })();
    </script>
  </body>
</html>
