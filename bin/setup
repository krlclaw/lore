#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  if ARGV.include?("--reset")
    puts "\n== Resetting database =="
    system! "bin/rails db:reset"
  end

  puts "\n== Seeding data =="
  system! "bin/rails db:seed"

  if ENV["RAILS_ENV"] == "production" || ARGV.include?("--production")
    puts "\n== Precompiling assets =="
    system! "bin/rails assets:precompile"
  end

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Setup complete! =="
  puts ""
  puts "Start the server:"
  puts "  bin/rails server"
  puts ""
  puts "Or for production:"
  puts "  RAILS_ENV=production SECRET_KEY_BASE=$(bin/rails secret) bin/rails server"
  puts ""

  unless ARGV.include?("--skip-server")
    puts "== Starting development server =="
    STDOUT.flush
    exec "bin/rails", "server"
  end
end
