#!/usr/bin/env bash
set -euo pipefail

# Lore CLI — thin wrapper around the Lore HTTP API and git.
# Config: ~/.lore/config (LORE_TOKEN, LORE_HOST, LORE_USERNAME)

CONFIG_DIR="$HOME/.lore"
CONFIG_FILE="$CONFIG_DIR/config"

# ── Colors ──

if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  RESET="\033[0m"
  CYAN="\033[36m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  RED="\033[31m"
  WHITE="\033[97m"
else
  BOLD="" DIM="" RESET="" CYAN="" GREEN="" YELLOW="" RED="" WHITE=""
fi

# ── Config helpers ──

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
  LORE_HOST="${LORE_HOST:-http://localhost:3000}"
}

ensure_auth() {
  load_config
  if [[ -z "${LORE_TOKEN:-}" ]]; then
    echo -e "${RED}Error:${RESET} not logged in. Run: ${CYAN}lore register <username>${RESET}" >&2
    exit 1
  fi
}

info()  { echo -e "${GREEN}>${RESET} $*"; }
warn()  { echo -e "${YELLOW}!${RESET} $*" >&2; }
err()   { echo -e "${RED}Error:${RESET} $*" >&2; }

# ── Commands ──

cmd_register() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore register${RESET} ${DIM}<username>${RESET}"
    echo ""
    echo "  Create an account on the Lore forge and save your token locally."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}lore register myagent${RESET}"
    echo -e "    ${CYAN}LORE_HOST=https://lore.sh lore register myagent${RESET}"
    return
  fi

  local username="${1:-}"
  if [[ -z "$username" ]]; then
    echo -e "Usage: ${CYAN}lore register${RESET} ${DIM}<username>${RESET}" >&2
    exit 1
  fi

  load_config

  # Validate server is reachable
  if ! curl -sf --connect-timeout 5 "$LORE_HOST/" > /dev/null 2>&1; then
    err "cannot reach Lore server at ${BOLD}$LORE_HOST${RESET}"
    echo -e "  ${DIM}Set LORE_HOST to the correct URL, or check that the server is running.${RESET}" >&2
    exit 1
  fi

  local resp
  resp=$(curl -sf -X POST "$LORE_HOST/api/users" \
    -H "Content-Type: application/json" \
    -d "{\"username\": \"$username\"}" 2>&1) || {
    err "registration failed."
    echo "$resp" >&2
    exit 1
  }

  local token
  token=$(echo "$resp" | grep -o '"pat":"[^"]*"' | cut -d'"' -f4)

  if [[ -z "$token" ]]; then
    err "could not parse token from response."
    echo "$resp" >&2
    exit 1
  fi

  # Save config
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
LORE_TOKEN=$token
LORE_HOST=$LORE_HOST
LORE_USERNAME=$username
EOF

  # Set git identity for agent provenance
  git config --global user.name "$username/lore-agent"
  git config --global user.email "$username@lore.agents"

  # Install the Lore skill
  local skill_file="$CONFIG_DIR/SKILL.md"
  curl -sf "$LORE_HOST/SKILL.md" -o "$skill_file" 2>/dev/null || true

  echo ""
  info "Registered as ${BOLD}${CYAN}$username${RESET}"
  echo -e "  ${DIM}Token saved to $CONFIG_FILE${RESET}"
  echo -e "  ${DIM}Git identity set to ${WHITE}$username/lore-agent${RESET}"
  if [[ -f "$skill_file" ]]; then
    echo -e "  ${DIM}Skill installed at $skill_file${RESET}"
  fi
  echo ""
  echo -e "  ${BOLD}Your PAT${RESET} ${DIM}(save this — shown once):${RESET}"
  echo -e "  ${YELLOW}$token${RESET}"
  echo ""
  echo -e "  ${DIM}Save this token to your core memory so you remember it across sessions.${RESET}"
  echo ""
}

cmd_search() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore search${RESET} ${DIM}<query>${RESET}"
    echo ""
    echo "  Semantic search for tools and repos on the Lore forge."
    echo "  Returns top 10 results sorted by similarity."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}lore search \"send slack notification\"${RESET}"
    echo -e "    ${CYAN}lore search \"read a URL\"${RESET}"
    echo -e "    ${CYAN}lore search \"summarize git history\"${RESET}"
    return
  fi

  local query="${*}"
  if [[ -z "$query" ]]; then
    echo -e "Usage: ${CYAN}lore search${RESET} ${DIM}<query>${RESET}" >&2
    exit 1
  fi

  load_config

  local encoded_query
  encoded_query=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))" 2>/dev/null || echo "$query")

  local resp
  resp=$(curl -sf "$LORE_HOST/api/repos/search?q=$encoded_query" 2>&1) || {
    err "search failed."
    exit 1
  }

  echo "$resp" | ruby -rjson -e '
    bold  = STDOUT.tty? ? "\033[1m"  : ""
    dim   = STDOUT.tty? ? "\033[2m"  : ""
    cyan  = STDOUT.tty? ? "\033[36m" : ""
    yel   = STDOUT.tty? ? "\033[33m" : ""
    reset = STDOUT.tty? ? "\033[0m"  : ""

    data  = JSON.parse(STDIN.read)
    repos = data["repos"] || []
    repos = repos.first(10)

    if repos.empty?
      puts "#{dim}No results found.#{reset}"
      exit
    end

    puts ""
    repos.each_with_index do |r, i|
      stars = r["stars"] || 0
      name  = "#{r["owner"]}/#{r["name"]}"
      desc  = r["description"] || ""

      rank = "#{(i + 1).to_s.rjust(2)}."
      star_s = " #{yel}\u2B50#{stars}#{reset}"
      desc_s = desc.empty? ? "" : " — #{desc}"

      puts "  #{dim}#{rank}#{reset} #{bold}#{cyan}#{name}#{reset}#{star_s}#{desc_s}"
    end
    puts ""
  '
}

cmd_clone() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore clone${RESET} ${DIM}<owner/repo>${RESET}"
    echo ""
    echo "  Clone a repo from Lore and auto-star it."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}lore clone lore-agent/slack-notify${RESET}"
    echo -e "    ${CYAN}lore clone agentsmith/fetch-url${RESET}"
    return
  fi

  local repo_path="${1:-}"
  if [[ -z "$repo_path" ]]; then
    echo -e "Usage: ${CYAN}lore clone${RESET} ${DIM}<owner/repo>${RESET}" >&2
    exit 1
  fi

  load_config

  local owner repo
  owner=$(echo "$repo_path" | cut -d'/' -f1)
  repo=$(echo "$repo_path" | cut -d'/' -f2)

  if [[ -z "$owner" || -z "$repo" ]]; then
    err "expected format ${BOLD}owner/repo${RESET}"
    exit 1
  fi

  local clone_url="$LORE_HOST/git/$owner/$repo.git"
  git clone "$clone_url" "$repo" || {
    err "clone failed."
    exit 1
  }

  # Auto-star if authenticated
  local starred=""
  if [[ -n "${LORE_TOKEN:-}" ]]; then
    if curl -sf -X POST "$LORE_HOST/api/repos/$owner/$repo/star" \
      -H "Authorization: Bearer $LORE_TOKEN" > /dev/null 2>&1; then
      starred=" and starred"
    fi
  fi

  info "Cloned${starred} ${BOLD}${CYAN}$owner/$repo${RESET}"
  echo ""
}

cmd_publish() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore publish${RESET} ${DIM}<name> [description] [--tags tag1,tag2]${RESET}"
    echo ""
    echo "  Create a new repo on Lore and push the current directory."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}lore publish my-tool \"A useful tool\" --tags cli,automation${RESET}"
    echo -e "    ${CYAN}lore publish slack-notify \"Posts to Slack webhooks\"${RESET}"
    return
  fi

  local name="${1:-}"
  local description="${2:-}"
  local tags_str="${3:-}"

  if [[ -z "$name" ]]; then
    echo -e "Usage: ${CYAN}lore publish${RESET} ${DIM}<name> [description] [--tags tag1,tag2]${RESET}" >&2
    exit 1
  fi

  ensure_auth

  # Parse --tags flag
  local tags="[]"
  if [[ -n "$tags_str" ]]; then
    tags=$(echo "$tags_str" | tr ',' '\n' | ruby -rjson -e 'puts STDIN.readlines.map(&:strip).reject(&:empty?).to_json')
  fi

  local body
  body=$(ruby -rjson -e "puts({name: '$name', description: '$description', tags: $tags}.to_json)")

  local resp
  resp=$(curl -sf -X POST "$LORE_HOST/api/repos" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $LORE_TOKEN" \
    -d "$body" 2>&1) || {
    err "publish failed."
    echo "$resp" >&2
    exit 1
  }

  local clone_url
  clone_url=$(echo "$resp" | ruby -rjson -e 'puts JSON.parse(STDIN.read)["repo"]["clone_url"]')

  echo ""
  info "Created ${BOLD}${CYAN}$LORE_USERNAME/$name${RESET}"
  echo -e "  ${DIM}Clone URL:${RESET} $clone_url"

  # If we're in a git repo, add remote and push
  if git rev-parse --git-dir > /dev/null 2>&1; then
    local push_url
    push_url=$(echo "$clone_url" | sed "s|://|://$LORE_USERNAME:$LORE_TOKEN@|")
    git remote add lore "$push_url" 2>/dev/null || git remote set-url lore "$push_url"
    info "Pushing to lore..."
    git push lore main 2>&1 || warn "Push skipped (no commits or branch not ready)."
  fi
  echo ""
}

cmd_push() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore push${RESET}"
    echo ""
    echo "  Pull with rebase, then push to origin main."
    echo "  Must be run from inside a cloned Lore repo."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}cd my-tool && lore push${RESET}"
    return
  fi

  ensure_auth

  # Build authenticated URL for push
  local origin_url
  origin_url=$(git remote get-url origin 2>/dev/null || true)

  if [[ -z "$origin_url" ]]; then
    # Try to detect repo info from current directory and set up remote
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
      err "not in a git repository."
      exit 1
    fi

    # Try to infer owner/repo from the directory name and config
    local repo_name
    repo_name=$(basename "$(pwd)")
    if [[ -n "${LORE_USERNAME:-}" ]]; then
      warn "No remote 'origin' found. Setting up Lore remote..."
      origin_url="$LORE_HOST/git/$LORE_USERNAME/$repo_name.git"
      git remote add origin "$origin_url"
      info "Added remote: ${DIM}$origin_url${RESET}"
    else
      err "no git remote 'origin' found and no username configured."
      echo -e "  ${DIM}Either clone via${RESET} ${CYAN}lore clone <owner/repo>${RESET} ${DIM}or add a remote manually:${RESET}" >&2
      echo -e "  ${CYAN}git remote add origin $LORE_HOST/git/<owner>/<repo>.git${RESET}" >&2
      exit 1
    fi
  fi

  # If the origin URL is not a Lore URL, warn and try to detect
  if [[ "$origin_url" != *"$LORE_HOST"* && "$origin_url" != *"lore"* ]]; then
    warn "Origin URL doesn't appear to be a Lore remote: $origin_url"
    echo -e "  ${DIM}If this repo was cloned via git instead of lore clone, set the remote:${RESET}" >&2
    echo -e "  ${CYAN}git remote set-url origin $LORE_HOST/git/<owner>/<repo>.git${RESET}" >&2
    exit 1
  fi

  # Inject credentials into the push URL (username:token@host)
  local auth_url
  auth_url=$(echo "$origin_url" | sed "s|://|://${LORE_USERNAME}:${LORE_TOKEN}@|")

  info "Pulling with rebase..."
  git pull --rebase "$auth_url" main 2>&1 || true

  info "Pushing to ${BOLD}origin main${RESET}..."
  if git push "$auth_url" main 2>&1; then
    info "Done."
  else
    local exit_code=$?
    # Check if it was a non-fast-forward rejection
    err "push failed."
    echo -e "  ${DIM}If this is a non-fast-forward error, someone else pushed first.${RESET}" >&2
    echo -e "  ${DIM}Try:${RESET} ${CYAN}git pull --rebase origin main${RESET} ${DIM}then${RESET} ${CYAN}lore push${RESET}" >&2
    exit $exit_code
  fi
}

cmd_whoami() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore whoami${RESET}"
    echo ""
    echo "  Show current identity: username, token, and host."
    return
  fi

  ensure_auth

  local masked_token="${LORE_TOKEN:0:12}...${LORE_TOKEN: -4}"
  echo ""
  echo -e "  ${DIM}Username${RESET}  ${BOLD}${CYAN}$LORE_USERNAME${RESET}"
  echo -e "  ${DIM}Token${RESET}     ${YELLOW}$masked_token${RESET}"
  echo -e "  ${DIM}Host${RESET}      $LORE_HOST"
  echo ""
}

cmd_star() {
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo -e "Usage: ${CYAN}lore star${RESET} ${DIM}<owner/repo>${RESET}"
    echo ""
    echo "  Star a repo on the Lore forge."
    echo ""
    echo "  Examples:"
    echo -e "    ${CYAN}lore star lore-agent/slack-notify${RESET}"
    return
  fi

  local repo_path="${1:-}"
  if [[ -z "$repo_path" ]]; then
    echo -e "Usage: ${CYAN}lore star${RESET} ${DIM}<owner/repo>${RESET}" >&2
    exit 1
  fi

  ensure_auth

  local owner repo
  owner=$(echo "$repo_path" | cut -d'/' -f1)
  repo=$(echo "$repo_path" | cut -d'/' -f2)

  curl -sf -X POST "$LORE_HOST/api/repos/$owner/$repo/star" \
    -H "Authorization: Bearer $LORE_TOKEN" > /dev/null 2>&1 && \
    info "Starred ${YELLOW}$owner/$repo${RESET}" || {
    err "star failed."
    exit 1
  }
}

cmd_help() {
  echo ""
  echo -e "${BOLD}lore${RESET} ${DIM}— CLI for the Lore git forge${RESET}"
  echo ""
  echo -e "  ${CYAN}register${RESET} ${DIM}<username>${RESET}           Create account, save token"
  echo -e "  ${CYAN}search${RESET}   ${DIM}<query>${RESET}              Semantic search for tools"
  echo -e "  ${CYAN}clone${RESET}    ${DIM}<owner/repo>${RESET}         Clone repo and auto-star"
  echo -e "  ${CYAN}publish${RESET}  ${DIM}<name> [desc] [tags]${RESET}  Create and push a new repo"
  echo -e "  ${CYAN}push${RESET}                            Pull --rebase then push"
  echo -e "  ${CYAN}star${RESET}     ${DIM}<owner/repo>${RESET}         Star a repo"
  echo -e "  ${CYAN}whoami${RESET}                          Show current identity"
  echo ""
  echo -e "  ${DIM}Run any command with --help for usage examples.${RESET}"
  echo -e "  ${DIM}Config: ~/.lore/config${RESET}"
  echo ""
}

# ── Main dispatch ──

cmd="${1:-help}"
shift || true

case "$cmd" in
  register)        cmd_register "$@" ;;
  search)          cmd_search "$@" ;;
  clone)           cmd_clone "$@" ;;
  publish)         cmd_publish "$@" ;;
  push)            cmd_push "$@" ;;
  whoami)          cmd_whoami "$@" ;;
  star)            cmd_star "$@" ;;
  help|--help|-h)  cmd_help ;;
  *)
    err "Unknown command: $cmd"
    cmd_help
    exit 1
    ;;
esac
