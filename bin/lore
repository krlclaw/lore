#!/usr/bin/env bash
set -euo pipefail

# Lore CLI — thin wrapper around the Lore HTTP API and git.
# Config: ~/.lore/config (LORE_TOKEN, LORE_HOST, LORE_USERNAME)

CONFIG_DIR="$HOME/.lore"
CONFIG_FILE="$CONFIG_DIR/config"

# ── Colors ──

if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  RESET="\033[0m"
  CYAN="\033[36m"
  GREEN="\033[32m"
  YELLOW="\033[33m"
  RED="\033[31m"
  WHITE="\033[97m"
else
  BOLD="" DIM="" RESET="" CYAN="" GREEN="" YELLOW="" RED="" WHITE=""
fi

# ── Config helpers ──

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi
  LORE_HOST="${LORE_HOST:-http://localhost:3000}"
}

ensure_auth() {
  load_config
  if [[ -z "${LORE_TOKEN:-}" ]]; then
    echo -e "${RED}Error:${RESET} not logged in. Run: ${CYAN}lore register <username>${RESET}" >&2
    exit 1
  fi
}

info()  { echo -e "${GREEN}>${RESET} $*"; }
warn()  { echo -e "${YELLOW}!${RESET} $*" >&2; }
err()   { echo -e "${RED}Error:${RESET} $*" >&2; }

# ── Commands ──

cmd_register() {
  local username="${1:-}"
  if [[ -z "$username" ]]; then
    echo -e "Usage: ${CYAN}lore register${RESET} ${DIM}<username>${RESET}" >&2
    exit 1
  fi

  load_config

  local resp
  resp=$(curl -sf -X POST "$LORE_HOST/api/users" \
    -H "Content-Type: application/json" \
    -d "{\"username\": \"$username\"}" 2>&1) || {
    err "registration failed."
    echo "$resp" >&2
    exit 1
  }

  local token
  token=$(echo "$resp" | grep -o '"pat":"[^"]*"' | cut -d'"' -f4)

  if [[ -z "$token" ]]; then
    err "could not parse token from response."
    echo "$resp" >&2
    exit 1
  fi

  # Save config
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
LORE_TOKEN=$token
LORE_HOST=$LORE_HOST
LORE_USERNAME=$username
EOF

  echo ""
  info "Registered as ${BOLD}${CYAN}$username${RESET}"
  echo -e "  ${DIM}Token saved to $CONFIG_FILE${RESET}"
  echo ""
  echo -e "  ${BOLD}Your PAT${RESET} ${DIM}(save this — shown once):${RESET}"
  echo -e "  ${YELLOW}$token${RESET}"
  echo ""
}

cmd_search() {
  local query="${*}"
  if [[ -z "$query" ]]; then
    echo -e "Usage: ${CYAN}lore search${RESET} ${DIM}<query>${RESET}" >&2
    exit 1
  fi

  load_config

  local encoded_query
  encoded_query=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))" 2>/dev/null || echo "$query")

  local resp
  resp=$(curl -sf "$LORE_HOST/api/repos/search?q=$encoded_query" 2>&1) || {
    err "search failed."
    exit 1
  }

  echo "$resp" | ruby -rjson -e '
    bold  = STDOUT.tty? ? "\033[1m"  : ""
    dim   = STDOUT.tty? ? "\033[2m"  : ""
    cyan  = STDOUT.tty? ? "\033[36m" : ""
    yel   = STDOUT.tty? ? "\033[33m" : ""
    green = STDOUT.tty? ? "\033[32m" : ""
    reset = STDOUT.tty? ? "\033[0m"  : ""

    data  = JSON.parse(STDIN.read)
    repos = data["repos"]
    if repos.empty?
      puts "#{dim}No results found.#{reset}"
      exit
    end

    puts ""
    repos.each_with_index do |r, i|
      stars = r["stars"] || 0
      score = ((r["similarity_score"] || 0) * 100).round(1)
      name  = "#{r["owner"]}/#{r["name"]}"

      # Line 1: rank, name, stars, score
      rank = "#{dim}#{(i + 1).to_s.rjust(2)}.#{reset}"
      star_s = stars > 0 ? " #{yel}\u2605 #{stars}#{reset}" : ""
      score_s = " #{dim}#{score}% match#{reset}"
      puts "#{rank} #{bold}#{cyan}#{name}#{reset}#{star_s}#{score_s}"

      # Line 2: description
      if r["description"] && !r["description"].empty?
        puts "      #{dim}#{r["description"]}#{reset}"
      end

      # Line 3: tags
      tags = r["tags"] || []
      if tags.any?
        tag_s = tags.map { |t| "#{green}#{t}#{reset}" }.join(" ")
        puts "      #{tag_s}"
      end
      puts "" if i < repos.length - 1
    end
    puts ""
  '
}

cmd_clone() {
  local repo_path="${1:-}"
  if [[ -z "$repo_path" ]]; then
    echo -e "Usage: ${CYAN}lore clone${RESET} ${DIM}<owner/repo>${RESET}" >&2
    exit 1
  fi

  load_config

  local owner repo
  owner=$(echo "$repo_path" | cut -d'/' -f1)
  repo=$(echo "$repo_path" | cut -d'/' -f2)

  if [[ -z "$owner" || -z "$repo" ]]; then
    err "expected format ${BOLD}owner/repo${RESET}"
    exit 1
  fi

  local clone_url="$LORE_HOST/git/$owner/$repo.git"
  info "Cloning ${BOLD}${CYAN}$owner/$repo${RESET}..."
  git clone "$clone_url" "$repo" || {
    err "clone failed."
    exit 1
  }

  # Auto-star if authenticated
  if [[ -n "${LORE_TOKEN:-}" ]]; then
    curl -sf -X POST "$LORE_HOST/api/repos/$owner/$repo/star" \
      -H "Authorization: Bearer $LORE_TOKEN" > /dev/null 2>&1 && \
      info "Starred ${YELLOW}$owner/$repo${RESET}" || true
  fi

  echo ""
  echo -e "  ${DIM}cd $repo && start hacking${RESET}"
  echo ""
}

cmd_publish() {
  local name="${1:-}"
  local description="${2:-}"
  local tags_str="${3:-}"

  if [[ -z "$name" ]]; then
    echo -e "Usage: ${CYAN}lore publish${RESET} ${DIM}<name> [description] [--tags tag1,tag2]${RESET}" >&2
    exit 1
  fi

  ensure_auth

  # Parse --tags flag
  local tags="[]"
  if [[ -n "$tags_str" ]]; then
    tags=$(echo "$tags_str" | tr ',' '\n' | ruby -rjson -e 'puts STDIN.readlines.map(&:strip).reject(&:empty?).to_json')
  fi

  local body
  body=$(ruby -rjson -e "puts({name: '$name', description: '$description', tags: $tags}.to_json)")

  local resp
  resp=$(curl -sf -X POST "$LORE_HOST/api/repos" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $LORE_TOKEN" \
    -d "$body" 2>&1) || {
    err "publish failed."
    echo "$resp" >&2
    exit 1
  }

  local clone_url
  clone_url=$(echo "$resp" | ruby -rjson -e 'puts JSON.parse(STDIN.read)["repo"]["clone_url"]')

  echo ""
  info "Created ${BOLD}${CYAN}$LORE_USERNAME/$name${RESET}"
  echo -e "  ${DIM}Clone URL:${RESET} $clone_url"

  # If we're in a git repo, add remote and push
  if git rev-parse --git-dir > /dev/null 2>&1; then
    local push_url
    push_url=$(echo "$clone_url" | sed "s|://|://$LORE_USERNAME:$LORE_TOKEN@|")
    git remote add lore "$push_url" 2>/dev/null || git remote set-url lore "$push_url"
    info "Pushing to lore..."
    git push lore main 2>&1 || warn "Push skipped (no commits or branch not ready)."
  fi
  echo ""
}

cmd_push() {
  ensure_auth

  # Build authenticated URL for push
  local origin_url
  origin_url=$(git remote get-url origin 2>/dev/null)
  if [[ -z "$origin_url" ]]; then
    err "no git remote 'origin' found. Are you in a cloned repo?"
    exit 1
  fi

  # Inject credentials into the push URL (username:token@host)
  local auth_url
  auth_url=$(echo "$origin_url" | sed "s|://|://${LORE_USERNAME}:${LORE_TOKEN}@|")

  info "Pulling with rebase..."
  git pull --rebase "$auth_url" main 2>&1 || true

  info "Pushing to ${BOLD}origin main${RESET}..."
  if git push "$auth_url" main 2>&1; then
    info "Done."
  else
    local exit_code=$?
    # Check if it was a non-fast-forward rejection
    err "push failed."
    echo -e "  ${DIM}If this is a non-fast-forward error, someone else pushed first.${RESET}" >&2
    echo -e "  ${DIM}Try:${RESET} ${CYAN}git pull --rebase origin main${RESET} ${DIM}then${RESET} ${CYAN}lore push${RESET}" >&2
    exit $exit_code
  fi
}

cmd_whoami() {
  ensure_auth

  local masked_token="${LORE_TOKEN:0:12}...${LORE_TOKEN: -4}"
  echo ""
  echo -e "  ${DIM}Username${RESET}  ${BOLD}${CYAN}$LORE_USERNAME${RESET}"
  echo -e "  ${DIM}Token${RESET}     ${YELLOW}$masked_token${RESET}"
  echo -e "  ${DIM}Host${RESET}      $LORE_HOST"
  echo ""
}

cmd_star() {
  local repo_path="${1:-}"
  if [[ -z "$repo_path" ]]; then
    echo -e "Usage: ${CYAN}lore star${RESET} ${DIM}<owner/repo>${RESET}" >&2
    exit 1
  fi

  ensure_auth

  local owner repo
  owner=$(echo "$repo_path" | cut -d'/' -f1)
  repo=$(echo "$repo_path" | cut -d'/' -f2)

  curl -sf -X POST "$LORE_HOST/api/repos/$owner/$repo/star" \
    -H "Authorization: Bearer $LORE_TOKEN" > /dev/null 2>&1 && \
    info "Starred ${YELLOW}$owner/$repo${RESET}" || {
    err "star failed."
    exit 1
  }
}

cmd_help() {
  echo ""
  echo -e "${BOLD}lore${RESET} ${DIM}— CLI for the Lore git forge${RESET}"
  echo ""
  echo -e "  ${CYAN}register${RESET} ${DIM}<username>${RESET}           Create account, save token"
  echo -e "  ${CYAN}search${RESET}   ${DIM}<query>${RESET}              Semantic search for tools"
  echo -e "  ${CYAN}clone${RESET}    ${DIM}<owner/repo>${RESET}         Clone repo and auto-star"
  echo -e "  ${CYAN}publish${RESET}  ${DIM}<name> [desc] [tags]${RESET}  Create and push a new repo"
  echo -e "  ${CYAN}push${RESET}                            Pull --rebase then push"
  echo -e "  ${CYAN}star${RESET}     ${DIM}<owner/repo>${RESET}         Star a repo"
  echo -e "  ${CYAN}whoami${RESET}                          Show current identity"
  echo ""
  echo -e "  ${DIM}Config: ~/.lore/config${RESET}"
  echo ""
}

# ── Main dispatch ──

cmd="${1:-help}"
shift || true

case "$cmd" in
  register)        cmd_register "$@" ;;
  search)          cmd_search "$@" ;;
  clone)           cmd_clone "$@" ;;
  publish)         cmd_publish "$@" ;;
  push)            cmd_push "$@" ;;
  whoami)          cmd_whoami "$@" ;;
  star)            cmd_star "$@" ;;
  help|--help|-h)  cmd_help ;;
  *)
    err "Unknown command: $cmd"
    cmd_help
    exit 1
    ;;
esac
